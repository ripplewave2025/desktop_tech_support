{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-backend",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "uvicorn", "api.server:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "ui-frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173", "--host", "127.0.0.1"],
      "port": 5173,
      "cwd": "ui"
    }
  ]
}
